{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".out/src",
    "composite": true,
    "noEmit": false
  },
  "include": ["src/**/*", "vite.config.ts"]
}
