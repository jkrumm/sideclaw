<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jkrumm.sideclaw</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/bun</string>
    <string>server/index.ts</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/johannes.krumm/SourceRoot/sideclaw</string>

  <!-- Bun auto-loads .env from WorkingDirectory — no need to repeat vars here -->

  <key>KeepAlive</key>
  <true/>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/sideclaw.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/sideclaw.err</string>
</dict>
</plist>
