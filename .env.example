PERSONAL_REPOS_PATH=/Users/yourname/SourceRoot
WORK_REPOS_PATH=/Users/yourname/IuRoot
# GitHub token for PR status, CI checks, and workflow runs
# Reuse local gh CLI session: GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=
# Set to "true" to enable the GitPanel: git status polling, GitHub API calls,
# chain/git actions. Disabled by default. Frontend reads the VITE_ var.
SIDECLAW_GIT_ENABLED=
VITE_SIDECLAW_GIT_ENABLED=
# Set to "true" to enable the QueuePanel: sc-queue.md reads/writes,
# completed-tasks endpoint, queue SSE watcher. Disabled by default. Frontend reads the VITE_ var.
SIDECLAW_QUEUE_ENABLED=
VITE_SIDECLAW_QUEUE_ENABLED=
