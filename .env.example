PERSONAL_REPOS_PATH=/Users/yourname/SourceRoot
WORK_REPOS_PATH=/Users/yourname/IuRoot
# GitHub token for PR status, CI checks, and workflow runs
# Reuse local gh CLI session: GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=
# Set to "true" to disable the GitPanel entirely: no git status polling,
# no GitHub API calls, no chain/git actions. Frontend reads the VITE_ var.
SIDECLAW_GIT_DISABLED=
VITE_SIDECLAW_GIT_DISABLED=
# Set to "true" to disable the QueuePanel entirely: no sc-queue.md reads/writes,
# no completed-tasks endpoint, no queue SSE watcher. Frontend reads the VITE_ var.
SIDECLAW_QUEUE_DISABLED=
VITE_SIDECLAW_QUEUE_DISABLED=
