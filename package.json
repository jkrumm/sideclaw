{
  "name": "sideclaw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src server",
    "format": "oxfmt src server --write",
    "format:check": "oxfmt src server --check",
    "start": "bun server/index.ts",
    "logs:tail": "tail -f /tmp/sideclaw.jsonl | bunx pino-pretty"
  },
  "dependencies": {
    "@blueprintjs/core": "6.10.0",
    "@blueprintjs/icons": "6.7.0",
    "@blueprintjs/select": "6.1.8",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/static": "1.4.7",
    "@excalidraw/excalidraw": "^0.18.0",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "@uiw/codemirror-themes": "^4.25.8",
    "@uiw/react-codemirror": "^4.25.8",
    "elysia": "1.4.28",
    "normalize.css": "8.0.1",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "pino-pretty": "^13.1.3",
    "typescript": "5.9.3",
    "vite": "8.0.1"
  }
}
